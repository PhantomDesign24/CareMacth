{
  "expo": {
    "name": "케어매치",
    "slug": "carematch-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kr.carematch.patient",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "생체 인증으로 빠르게 로그인합니다.",
        "NSLocationWhenInUseUsageDescription": "간병 위치 확인을 위해 위치 정보가 필요합니다.",
        "NSCameraUsageDescription": "환자 관련 이미지 업로드를 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "환자 관련 이미지 업로드를 위해 사진 접근이 필요합니다.",
        "NSPhotoLibraryAddOnlyUsageDescription": "환자 관련 사진 저장을 위해 권한이 필요합니다.",
        "UIBackgroundModes": ["remote-notification"],
        "LSApplicationQueriesSchemes": [
          "kakaotalk",
          "kakaopay",
          "kakaolink",
          "supertoss",
          "payco",
          "ispmobile",
          "kftc-bankpay",
          "mpocket.online.ansimclick",
          "kb-acp",
          "hdcardappcardansimclick",
          "smshinhanansimclick",
          "smlotteapp",
          "lottesmartpay",
          "lotteappcard",
          "cloudpay",
          "nhappcardansimclick",
          "citispay",
          "samsungpay",
          "tmap"
        ]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "googleServicesFile": "./google-services.json",
      "package": "kr.carematch.patient",
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "newArchEnabled": false
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF922E"
        }
      ],
      "./plugins/withAndroidQueries.js",
      "./plugins/withAndroidFinishAndRemoveTask.js"
    ],
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#FF922E"
    },
    "scheme": "carematch",
    "extra": {
      "eas": {
        "projectId": "carematch-patient"
      }
    }
  }
}
