# Database
DATABASE_URL="postgresql://user:password@localhost:5432/carematch?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_REDIRECT_URI="https://cm.phantomdesign.kr/api/auth/kakao/callback"

# Naver OAuth
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
NAVER_REDIRECT_URI="https://cm.phantomdesign.kr/api/auth/naver/callback"

# 토스페이먼츠
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# Firebase (푸시 알림)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Server
PORT=4000
NODE_ENV=development

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 채널톡
CHANNEL_TALK_PLUGIN_KEY=""
CHANNEL_TALK_SECRET=""
